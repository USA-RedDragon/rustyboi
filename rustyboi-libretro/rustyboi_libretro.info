# Software Information
display_name = "Nintendo - Game Boy / Game Boy Color (rustyboi)"
authors = "Jacob McSwain"
supported_extensions = "gb|gbc|zip"
corename = "rustyboi"
categories = "Emulator"
license = "MIT"
permissions = ""
display_version = "0.1.0"

# Hardware Information
manufacturer = "Nintendo"
systemname = "Game Boy / Game Boy Color"
systemid = "game_boy"

# Libretro Features
database = "Nintendo - Game Boy|Nintendo - Game Boy Color"
supports_no_game = "false"
savestate = "true"
savestate_features = "serialized"
cheats = "true"
input_descriptors = "true"
memory_descriptors = "true"
libretro_saves = "true"
core_options = "true"
core_options_version = "2.0"
load_subsystem = "false"
hw_render = "false"
needs_fullpath = "false"
disk_control = "false"
is_experimental = "false"

# Firmware / BIOS
# rustyboi boots without an external BIOS (skip_bios), so nothing here is
# required. The Super Game Boy dumps are optional and only ever presentational:
# with one in the system directory the SGB shows its own power-on border (the
# "SGB System Border" core option) until a game uploads its own.
firmware_count = 2
firmware0_desc = "sgb1.sfc (Super Game Boy SNES firmware, optional)"
firmware0_path = "sgb1.sfc"
firmware0_opt = "true"
firmware1_desc = "sgb2.sfc (Super Game Boy 2 SNES firmware, optional)"
firmware1_path = "sgb2.sfc"
firmware1_opt = "true"

description = "rustyboi is a cycle-accurate Game Boy / Game Boy Color emulator written in Rust. This libretro core provides video, audio, joypad input, runtime-serialized save states, battery SRAM and MBC3 RTC persistence, Game Genie / GameShark cheats, memory maps for RetroAchievements and RAM tools, MBC5 rumble, and selectable hardware model plus DMG palette and GBC colour-correction options. Sensors (accelerometer / light / microphone) and link-cable multiplayer are unsupported."
