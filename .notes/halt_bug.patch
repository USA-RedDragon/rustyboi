 pub fn halt(cpu: &mut cpu::SM83, mmio: &mut crate::cpu::Bus) -> u32 {
+    // HALT bug: with IME=0 and a pending interrupt (IE & IF != 0), the CPU does
+    // not enter the halt state; the next opcode fetch fails to advance PC, so
+    // the byte after HALT is executed twice.
+    if !cpu.registers.ime && cpu.has_pending_interrupt(mmio) {
+        cpu.halt_bug = true;
+        return 4;
+    }
     cpu.halted = true;
     // Capture the HDMA halt-state for the unhalt path. Mirrors Gambatte's
     // `Memory::halt`.
