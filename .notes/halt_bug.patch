 pub fn halt(cpu: &mut cpu::SM83, mmio: &mut crate::cpu::Bus) -> u32 {
+    // HALT bug: with a pending interrupt (IE & IF != 0) the CPU does not enter
+    // the halt state; the next opcode fetch fails to advance PC, so the byte
+    // after HALT is executed twice. This mirrors Gambatte (cpu.cpp case 0x76):
+    // the pending check is IME-independent. If IME is (or becomes) enabled the
+    // interrupt is serviced instead, and `service_interrupt` clears `halt_bug`
+    // so the queued PC anomaly is discarded (Gambatte's "undo prefetch").
+    if cpu.has_pending_interrupt(mmio) {
+        cpu.halt_bug = true;
+        return 4;
+    }
     cpu.halted = true;
     // Capture the HDMA halt-state for the unhalt path. Mirrors Gambatte's
     // `Memory::halt`.
