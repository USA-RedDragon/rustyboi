dma_timing_a|dmg|memauto|gb-test-roms/gbmicrotest/dma_timing_a.gb
# flood_vram: fills $8000-9FFF with $FF (`ld a,$FF / ld (hl+),a` until bit5 of B).
# The verdict is VRAM holding the flooded value; $8000=$FF.
flood_vram|dmg|mem|gb-test-roms/gbmicrotest/flood_vram.gb|8000=FF
